# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# ─── Python Agent (ipulse_agent/) ───────────────────────────────────────────

# Virtual environment — never commit this
ipulse_agent/venv/
ipulse_agent/.venv/
venv/
.venv/

# Python bytecode cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Python egg / distribution
*.egg
*.egg-info/
dist/
build/
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff / linting cache
.ruff_cache/

# AI model weight caches
*.ckpt
*.safetensors
*.bin
*.pt
*.pth

# Agent runtime output (generated media — large binary files)
ipulse_agent/videos/
ipulse_agent/images/
ipulse_agent/final/
ipulse_agent/scripts/
ipulse_agent/audio/

# Agent logs
ipulse_agent/*.log
ipulse_agent/logs/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# macOS
.DS_Store
**/.DS_Store

# Windows
Thumbs.db
desktop.ini

# Editor
.idea/
.vscode/settings.json
*.swp
*.swo
